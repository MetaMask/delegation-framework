pragma solidity 0.8.23;

import "forge-std/Test.sol";

import { BridgeDecoder } from "../../src/helpers/BridgeDecoder.sol";
import { TreasuryCalldataDecoder } from "../../src/helpers/libraries/TreasuryCalldataDecoder.sol";

/// @dev Run: `forge test --match-contract BridgeDecoderDecodeTest -vv`
contract BridgeDecoderDecodeTest is Test {
    BridgeDecoder internal decoder;

    function setUp() public {
        decoder = new BridgeDecoder();
    }

    function test_decodeSampleBridgeCalldata1_outerAndInner() public {
        bytes memory bridgeCalldata =
            hex"";

        (string memory adapterId,, uint256 amountFrom, bytes memory bridgeData) = decoder.decodeOuterBridgeCalldata(bridgeCalldata);

        assertEq(adapterId, "relayAdapterV2");
        assertEq(amountFrom, 100_000_000_000_000);

        TreasuryCalldataDecoder.BridgeAdapterDecoded memory inner = decoder.decodeBridgeAdapterTail(bridgeData);
        assertEq(inner.destinationChainId, 1);
        assertEq(inner.tokenFrom, address(0));
        assertEq(inner.amountFrom, 99_125_000_000_000);
    }

    function test_decodeSampleBridgeCalldata2_outerAndInner() public {
        bytes memory bridgeCalldata =
            hex"";

        (string memory adapterId,, uint256 amountFrom, bytes memory bridgeData) = decoder.decodeOuterBridgeCalldata(bridgeCalldata);

        assertEq(adapterId, "relayAdapterV2");
        assertEq(amountFrom, 10_000_000_000);

        TreasuryCalldataDecoder.BridgeAdapterDecoded memory inner = decoder.decodeBridgeAdapterTail(bridgeData);
        assertEq(inner.destinationChainId, 1);
        assertEq(inner.tokenFrom, 0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174);
        assertEq(inner.tokenTo, 0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48);
        assertEq(inner.amountFrom, 9_912_500_000);
    }
}
