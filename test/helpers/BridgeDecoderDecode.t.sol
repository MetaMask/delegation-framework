pragma solidity 0.8.23;

/* solhint-disable max-line-length */

import "forge-std/Test.sol";

import { IERC20 } from "@openzeppelin/contracts/token/ERC20/IERC20.sol";

import { BridgeDecoder } from "../../src/helpers/BridgeDecoder.sol";
import { TreasuryCalldataDecoder } from "../../src/helpers/libraries/TreasuryCalldataDecoder.sol";

/// @dev Fixtures from `MetaSwapAndMetaBridgeQuotes.json`: Linea USDC→ETH USDC and Base USDC→ETH USDC `bestQuote.tradeData`.
///      Run: `forge test --match-contract BridgeDecoderDecodeTest`
contract BridgeDecoderDecodeTest is Test {
    BridgeDecoder internal decoder;

    /// @dev Ethereum mainnet USDC (`tokenTo` in both bridge quotes).
    address internal constant USDC_MAINNET = 0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48;

    function setUp() public {
        decoder = new BridgeDecoder();
    }

    function test_decodeSampleBridgeCalldata1_outerAndInner() public {
        bytes memory bridgeCalldata =
            hex"";

        (string memory adapterId, IERC20 tokenFromOuter, uint256 amountFrom, bytes memory bridgeData) =
            decoder.decodeOuterBridgeCalldata(bridgeCalldata);

        assertEq(adapterId, "circleCctpAdapterV2");
        assertEq(address(tokenFromOuter), 0x176211869cA2b568f2A7D4EE941E073a821EE1ff);
        assertEq(amountFrom, 10_000_000_000);
        assertEq(bridgeData.length, 672);

        TreasuryCalldataDecoder.BridgeAdapterDecoded memory inner = decoder.decodeBridgeAdapterTail(bridgeData);

        assertEq(inner.destWalletAddress, address(0));
        assertEq(inner.aggregator, 0x28b5a0e9C621a5BadaA536219b3a228C8168cf5d);
        assertEq(inner.spender, 0x28b5a0e9C621a5BadaA536219b3a228C8168cf5d);
        assertEq(inner.destinationChainId, 1);
        assertEq(inner.tokenFrom, 0x176211869cA2b568f2A7D4EE941E073a821EE1ff);
        assertEq(inner.tokenTo, USDC_MAINNET);
        assertEq(inner.amountFrom, 9_912_500_000);
        assertEq(inner.fee, 87_500_000);
        assertEq(inner.feeWallet, 0xB87644b0Bd6AF792C022dc4958B3FaAA84D74d08);
        assertEq(inner.aggregatorCalldata.length, 324);
    }

    function test_decodeSampleBridgeCalldata2_outerAndInner() public {
        bytes memory bridgeCalldata =
            hex"";

        (string memory adapterId, IERC20 tokenFromOuter, uint256 amountFrom, bytes memory bridgeData) =
            decoder.decodeOuterBridgeCalldata(bridgeCalldata);

        assertEq(adapterId, "mayanFeeDynamic");
        assertEq(address(tokenFromOuter), 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913);
        assertEq(amountFrom, 10_000_000_000);
        assertEq(bridgeData.length, 896);

        TreasuryCalldataDecoder.BridgeAdapterDecoded memory inner = decoder.decodeBridgeAdapterTail(bridgeData);

        assertEq(inner.destWalletAddress, address(0));
        assertEq(inner.aggregator, 0x337685fdaB40D39bd02028545a4FfA7D287cC3E2);
        assertEq(inner.spender, 0x337685fdaB40D39bd02028545a4FfA7D287cC3E2);
        assertEq(inner.destinationChainId, 1);
        assertEq(inner.tokenFrom, 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913);
        assertEq(inner.tokenTo, USDC_MAINNET);
        assertEq(inner.amountFrom, 9_912_500_000);
        assertEq(inner.fee, 87_500_000);
        assertEq(inner.feeWallet, 0x675d5CEbAE87ecb8aCC7f057E95156f7Be9697D1);
        assertEq(inner.aggregatorCalldata.length, 548);
    }
}
